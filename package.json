{
  "name": "puppetty",
  "version": "0.2.0",
  "description": "Run commands under a pseudo-terminal that auto-answers interactive prompts (or delegates the decision to an AI agent), so scripts never hang waiting for input.",
  "type": "module",
  "bin": {
    "puppetty": "bin/puppetty.js"
  },
  "files": [
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pty",
    "conpty",
    "expect",
    "automation",
    "ai-agent",
    "terminal",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puppetty-org/puppetty.git"
  },
  "homepage": "https://github.com/puppetty-org/puppetty#readme",
  "bugs": {
    "url": "https://github.com/puppetty-org/puppetty/issues"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@puppetty/win32-x64": "0.2.0",
    "@puppetty/linux-x64-gnu": "0.2.0",
    "@puppetty/linux-arm64-gnu": "0.2.0",
    "@puppetty/darwin-x64": "0.2.0",
    "@puppetty/darwin-arm64": "0.2.0"
  }
}
