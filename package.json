{
  "name": "puppetty",
  "version": "0.1.0",
  "description": "Run commands under a pseudo-terminal that auto-answers interactive prompts (or delegates the decision to an AI agent), so scripts never hang waiting for input.",
  "type": "module",
  "bin": {
    "puppetty": "bin/puppetty.js"
  },
  "files": [
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "demo": "node bin/puppetty.js --auto -- node demo/prompt-demo.js",
    "demo:decider": "node bin/puppetty.js --decider \"node demo/decider-echo.js\" -- node demo/freeform-demo.js",
    "demo:password": "node bin/puppetty.js --auto --prompt-timeout 3 -- node demo/password-demo.js"
  },
  "keywords": [
    "pty",
    "conpty",
    "expect",
    "automation",
    "ai-agent",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puppetty-org/puppetty.git"
  },
  "homepage": "https://github.com/puppetty-org/puppetty#readme",
  "bugs": {
    "url": "https://github.com/puppetty-org/puppetty/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "zod": "^4.4.3"
  }
}
